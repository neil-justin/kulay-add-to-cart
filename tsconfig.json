{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/src/*": [
        "./src/*"
      ],
      "@/components": [
        "./src/components"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/hooks": [
        "./src/hooks"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/interfaces": [
        "./src/interfaces"
      ],
      "@/interfaces/*": [
        "./src/interfaces/*"
      ],
      "@/constants": [
        "./src/constants"
      ],
      "@/constants/*": [
        "./src/constants/*"
      ],
      "@/context": [
        "./src/context"
      ],
      "@/context/*": [
        "./src/context/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}